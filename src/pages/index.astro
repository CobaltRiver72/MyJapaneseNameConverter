---
<HomeLayout
  title="My Name in Japanese | Free Japanese Name Converter"
  description="Write your name in Japanese. Free translator for Katakana, Hiragana, and Kanji. Instant conversion, pronunciation guide, and romaji."
  canonical="https://myjapanesenametranslator.com/"
  csp={csp}
>
  <Fragment slot="schema" set:html={schema} />

    <!-- HERO -->
    <section class="hero">
        <div class="hero-kanji k1" aria-hidden="true">名</div>
        <div class="hero-kanji k2" aria-hidden="true">前</div>
        <div class="hero-kanji k3" aria-hidden="true">変</div>
        <div class="hero-kanji k4" aria-hidden="true">換</div>
        <div class="hero-content">
            <div class="hero-badge animate-in delay-1">My Japanese Name Translator</div>
            <h1 class="animate-in delay-2">Japanese Name Converter</h1>
            <p class="animate-in delay-3">
    Convert your English name into Katakana, Hiragana, or Kanji with pronunciation and cultural context.
</p>

        </div>
    </section>

    <!-- MAIN CONTENT -->
    <main id="main-content" role="main">

    <!-- CONVERTER -->
    <section class="converter-section animate-in delay-4" id="converter">
        <div class="converter-card">
            <div class="converter-inner">
                <label for="nameInput" class="converter-label">Enter Your Name in English</label>
                <div class="input-row">
                    <input type="text" class="name-input" id="nameInput" placeholder="e.g. Alexander, Emma, Sakura..." autocomplete="off" autofocus>
                    <button class="convert-btn" id="convertBtn" onclick="convertName()">
                        Convert
                    </button>
                </div>
                <div class="script-toggles">
                    <button class="script-toggle active" data-script="katakana" aria-pressed="true">Katakana <span class="jp">カタカナ</span></button>
                    <button class="script-toggle active" data-script="hiragana" aria-pressed="true">Hiragana <span class="jp">ひらがな</span></button>
                    <button class="script-toggle active" data-script="kanji" aria-pressed="true">Kanji <span class="jp">漢字</span></button>
                    <button class="script-toggle active" data-script="romaji" aria-pressed="true">Romaji</button>
                    <button class="script-toggle clear-toggle" id="clearBtn" onclick="clearName()">Clear</button>
                </div>

                <!-- RESULTS -->
                <h2 class="results-heading">Your Name in Japanese</h2>
                <div class="results-area is-placeholder" id="resultsArea" aria-live="polite" aria-atomic="false">
                    <div class="result-block" id="resultKatakana">
                        <div>
                            <div class="preview-label">Preview</div>
                            <div class="result-script-label">Katakana · カタカナ</div>
                            <div class="result-japanese" id="katakanaOutput">エマ</div>
                            <div class="result-romaji" id="katakanaRomaji">Ema</div>
                        </div>
                        <div class="result-actions">
                            <button class="action-btn" aria-label="Copy Katakana to clipboard" onclick="copyResult('katakanaOutput')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                            </button>
                            <button class="action-btn" id="speakKatakana" aria-label="Listen to Katakana" onclick="speakResult('katakanaOutput', 'ja-JP', 'speakKatakana')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                            </button>
                        </div>
                    </div>
                    <div class="result-block" id="resultHiragana">
                        <div>
                            <div class="preview-label">Preview</div>
                            <div class="result-script-label">Hiragana · ひらがな</div>
                            <div class="result-japanese" id="hiraganaOutput">えま</div>
                            <div class="result-romaji" id="hiraganaRomaji">Ema</div>
                        </div>
                        <div class="result-actions">
                            <button class="action-btn" aria-label="Copy Hiragana to clipboard" onclick="copyResult('hiraganaOutput')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                            </button>
                            <button class="action-btn" id="speakHiragana" aria-label="Listen to Hiragana" onclick="speakResult('hiraganaOutput', 'ja-JP', 'speakHiragana')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                            </button>
                        </div>
                    </div>
                    <div class="result-block" id="resultKanji">
                        <div>
                            <div class="preview-label">Preview</div>
                            <div class="result-script-label">Kanji · 漢字</div>
                            <div class="result-japanese" id="kanjiOutput">恵真</div>
                            <div class="result-romaji" id="kanjiRomaji">Ema (ateji)</div>
                        </div>
                        <div class="result-actions">
                            <button class="action-btn" aria-label="Copy Kanji to clipboard" onclick="copyResult('kanjiOutput')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                            </button>
                            <button class="action-btn" id="speakKanji" aria-label="Listen to Kanji" onclick="speakResult('kanjiOutput', 'ja-JP', 'speakKanji')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                            </button>
                        </div>
                    </div>
                    <div class="result-block" id="resultRomaji">
                        <div>
                            <div class="preview-label">Preview</div>
                            <div class="result-script-label">Romaji · Romanization</div>
                            <div class="result-japanese" id="romajiOutput">Ema</div>
                        </div>
                        <div class="result-actions">
                            <button class="action-btn" aria-label="Copy Romaji to clipboard" onclick="copyResult('romajiOutput')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                            </button>
                            <button class="action-btn" id="speakRomaji" aria-label="Listen to Romaji" onclick="speakResult('romajiOutput', 'en-US', 'speakRomaji')">
