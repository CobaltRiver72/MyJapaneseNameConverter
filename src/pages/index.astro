        let romaji = name;
        const rules = [
            [/ph/g, 'f'], [/th/g, 's'], [/ck/g, 'kk'],
            [/sh/g, 'sh'], [/ch/g, 'ch'], [/tch/g, 'cch'],
            [/wh/g, 'w'], [/wr/g, 'r'], [/kn/g, 'n'],
            [/ght/g, 'to'], [/tion/g, 'shon'], [/sion/g, 'shon'],
            [/qu/g, 'kw'], [/x/g, 'kusu'], [/c(?=[eiy])/g, 's'],
            [/c/g, 'k'], [/l/g, 'r'], [/v/g, 'b'],
            [/ee/g, 'ii'], [/oo/g, 'uu'],
            [/ey$/g, 'ei'], [/ay$/g, 'ei'], [/ly$/g, 'rii'],
            [/y$/g, 'i'], [/er$/g, 'aa'], [/ar$/g, 'aa'],
            [/or$/g, 'oo'], [/le$/g, 'ru'], [/ce$/g, 'su'],
