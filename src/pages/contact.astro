---
import LegalLayout from '../layouts/LegalLayout.astro';
---
<LegalLayout
  title="Contact Us | My Japanese Name Translator"
  description="Contact My Japanese Name Translator. Reach out to Daniel Sato for questions about Japanese name translations, kanji meanings, or any inquiries. Response within 24-48 hours."
  canonical="https://myjapanesenametranslator.com/contact"
  ogDescription="Contact My Japanese Name Translator. Reach out for questions about Japanese name translations, kanji meanings, or any inquiries."
  twitterDescription="Contact My Japanese Name Translator for questions about Japanese name translations and kanji meanings."
  bannerKanji1="連"
  bannerKanji2="絡"
  bannerTitle="Contact Us"
  bannerSubtitle="Have a question about your Japanese name? We'd love to hear from you"
  currentPage="contact"
>
  <Fragment slot="schema" set:html={`
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://myjapanesenametranslator.com/#danielsato",
          "name": "Daniel Sato",
          "givenName": "Daniel",
          "familyName": "Sato",
          "jobTitle": "Japanese Linguistics Expert & Name Translation Specialist",
          "description": "Developer and Japanese linguist specializing in English to Japanese name conversion using culturally accurate kanji, katakana, and hiragana transliteration methods.",
          "knowsLanguage": ["en", "ja"],
          "knowsAbout": [
            {
              "@type": "Thing",
              "name": "Japanese language",
              "sameAs": "https://en.wikipedia.org/wiki/Japanese_language"
            },
            {
              "@type": "Thing",
              "name": "Katakana",
              "sameAs": "https://en.wikipedia.org/wiki/Katakana"
            },
            {
              "@type": "Thing",
              "name": "Japanese names",
              "sameAs": "https://en.wikipedia.org/wiki/Japanese_name"
            },
            {
              "@type": "Thing",
              "name": "Transliteration",
              "sameAs": "https://en.wikipedia.org/wiki/Transliteration"
            }
          ],
          "sameAs": [
            "https://www.linkedin.com/in/daniel-sato-japanese/",
            "https://github.com/DanielJapanese",
            "https://www.pinterest.com/Danielsatojapanese/",
            "https://bsky.app/profile/danielsatojapanese.bsky.social",
            "https://linktr.ee/danielsatojapanese"
          ],
          "worksFor": {
            "@id": "https://myjapanesenametranslator.com/#organization"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://myjapanesenametranslator.com/#organization",
          "name": "My Japanese Name Translator",
          "alternateName": ["MJNT", "Japanese Name Translator"],
          "url": "https://myjapanesenametranslator.com/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://myjapanesenametranslator.com/My-Japanese-Name-Translator-Logo.png",
            "width": 512,
            "height": 512
          },
          "image": "https://myjapanesenametranslator.com/My-Japanese-Name-Translator-Logo.png",
          "founder": {
            "@id": "https://myjapanesenametranslator.com/#danielsato"
          },
          "foundingDate": "2026",
          "areaServed": "Worldwide",
          "slogan": "Translate Your Name in Japanese",
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "contact@myjapanesenametranslator.com",
            "contactType": "customer support",
            "availableLanguage": ["English", "Japanese"],
            "areaServed": "Worldwide"
          },
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Stockton",
            "addressRegion": "CA",
            "addressCountry": "US"
          },
          "sameAs": [
            "https://github.com/DanielJapanese",
            "https://www.pinterest.com/Danielsatojapanese/",
            "https://www.linkedin.com/in/daniel-sato-japanese/",
            "https://bsky.app/profile/danielsatojapanese.bsky.social",
            "https://linktr.ee/danielsatojapanese",
            "https://app.raindrop.io/my/66496713"
          ],
          "knowsAbout": [
            {
              "@type": "Thing",
              "name": "Japanese writing system",
              "sameAs": "https://en.wikipedia.org/wiki/Japanese_writing_system"
            },
            {
              "@type": "Thing",
              "name": "Name translation",
              "sameAs": "https://en.wikipedia.org/wiki/Transcription_(linguistics)"
            }
          ]
        },
        {
          "@type": "ContactPage",
          "@id": "https://myjapanesenametranslator.com/contact#webpage",
          "url": "https://myjapanesenametranslator.com/contact.html",
          "name": "Contact Us | My Japanese Name Translator",
          "description": "Contact My Japanese Name Translator. Reach out to Daniel Sato for questions about Japanese name translations, kanji meanings, or any inquiries.",
          "isPartOf": {
            "@id": "https://myjapanesenametranslator.com/#website"
          },
          "inLanguage": "en",
          "author": {
            "@id": "https://myjapanesenametranslator.com/#danielsato"
          },
          "publisher": { "@id": "https://myjapanesenametranslator.com/#organization" },
          "datePublished": "2026-01-01",
          "dateModified": "2026-02-06",
          "breadcrumb": {
            "@id": "https://myjapanesenametranslator.com/contact#breadcrumb"
          }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://myjapanesenametranslator.com/contact#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://myjapanesenametranslator.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
