---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  csp: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  twitterTitle?: string;
  twitterDescription?: string;
}

const props = Astro.props;
---
<BaseLayout {...props}>
    <Fragment slot="head-extra"><link rel="stylesheet" href="/styles.css?v=20260703"></Fragment>
    <slot name="schema" slot="schema" />

    <!-- SKIP LINK -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header currentPage="home" nameTranslatorHref="#converter" />

    <slot />

    <Footer nameTranslatorHref="#converter" />

    <!-- COPIED TOAST -->
    <div class="copied-toast" id="copiedToast" role="status" aria-live="polite">✓ Copied to clipboard</div>
    <div class="copied-toast" id="ttsToast" role="status" aria-live="polite">Text-to-speech not supported in this browser</div>

    <Fragment set:html={'<script src="/script.js?v=20260701"></script>'} />
</BaseLayout>
