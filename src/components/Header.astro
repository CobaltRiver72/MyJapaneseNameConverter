---
interface Props {
  currentPage?: 'home' | 'about' | 'contact' | 'converter' | 'none';
  nameTranslatorHref: string;
}

const { currentPage = 'none', nameTranslatorHref } = Astro.props;
---
    <!-- HEADER -->
    <header class="site-header" role="banner">
        <a href="/" class="logo" aria-label="My Japanese Name Translator - Home">
            <img src="https://myjapanesenametranslator.com/My-Japanese-Name-Translator-Logo.png" alt="My Japanese Name Translator Logo" class="logo-img" width="132" height="44">
        </a>
        <button class="mobile-menu-btn" aria-label="Toggle navigation menu" aria-expanded="false" onclick="toggleMobileNav()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <nav class="header-nav" role="navigation" aria-label="Main navigation">
            <a href="/" aria-current={currentPage === 'home' ? 'page' : undefined}>Home</a>
            <a href={nameTranslatorHref}>Name Translator</a>
            <div class="nav-dropdown">
                <a href="/converter" aria-current={currentPage === 'converter' ? 'page' : undefined} aria-haspopup="true">Converter Tools <span class="nav-caret" aria-hidden="true">▾</span></a>
                <div class="nav-dropdown-menu" aria-label="Converter tools">
                    <a href="/converter">All Converter Tools</a>
                    <a href="/kanji-finder">Kanji Finder (Draw)</a>
                    <a href="/kanji-to-hiragana-converter.html">Kanji to Hiragana</a>
                    <a href="/converter/kanji-to-katakana">Kanji to Katakana</a>
                    <a href="/converter/hiragana-to-katakana">Hiragana to Katakana</a>
                </div>
            </div>
            <a href="/about.html" aria-current={currentPage === 'about' ? 'page' : undefined}>About</a>
            <a href="/contact.html" aria-current={currentPage === 'contact' ? 'page' : undefined}>Contact</a>
        </nav>
    </header>
